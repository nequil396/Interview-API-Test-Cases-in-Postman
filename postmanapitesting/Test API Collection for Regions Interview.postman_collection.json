      "name": "POST Create Post",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "let data = pm.response.json();\r",
              "\r",
              "pm.test(\"Post created successfully\", function () {\r",
              "    pm.expect(data).to.have.property(\"id\");\r",
              "});\r",
              "\r",
              "pm.test(\"Title matches request\", function () {\r",
              "    pm.expect(data.title).to.eql(\"Test Post\");\r",
              "});\r",
              "\r",
              "pm.environment.set(\"post_id\", pm.response.json().id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
